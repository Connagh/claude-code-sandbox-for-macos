(version 1)

;; Claude Code Sandbox Profile
;; Deny-by-default. Only the working directory and system essentials
;; can be read. See README for details.

;; --- baseline ---
(deny default)
(allow network*)

;; --- deny reads across entire filesystem, especially home ---
(deny file-read*
  (subpath "/")
  (subpath "/Users")
  (subpath (param "USER_HOME"))
  (subpath (string-append (param "USER_HOME") "/.ssh"))
)

;; --- system paths needed to launch processes ---
(allow file-read*
  (subpath "/usr")
  (subpath "/bin")
  (subpath "/opt")
  (subpath "/var")
  (subpath "/private/var")
  (subpath "/etc")
  (subpath "/private/etc")
  (subpath "/System")
  (subpath "/Library/Java")
  (subpath "/nix")
  (literal "/")
)

;; nix-darwin: /run/current-system/sw/bin
(allow file-read-metadata (subpath "/run"))

;; --- user dotfiles (read-only) ---
(allow file-read*
  (subpath (string-append (param "USER_HOME") "/.config/git"))
  (subpath (string-append (param "USER_HOME") "/.config/jj"))
  (literal (string-append (param "USER_HOME") "/.gitconfig"))
  (subpath (string-append (param "USER_HOME") "/.config/nix"))
  (subpath (string-append (param "USER_HOME") "/.nix-profile"))
  (subpath (string-append (param "USER_HOME") "/.local/state/nix"))
)

;; --- working directory + temp + caches (read & write) ---
(allow file-read* file-write* file-write-create file-read-metadata file-ioctl
  ;; project workspace
  (subpath (param "WORK_DIR"))
  ;; temp
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders")
  (subpath "/private/var/folders")
  ;; claude config & caches
  (subpath (string-append (param "USER_HOME") "/.claude"))
  (literal (string-append (param "USER_HOME") "/.claude.json"))
  (literal (string-append (param "USER_HOME") "/.claude.json.backup"))
  (subpath (string-append (param "USER_HOME") "/Library/Caches/claude-cli-nodejs"))
  (subpath (string-append (param "USER_HOME") "/.cache"))
  ;; gemini config
  (subpath (string-append (param "USER_HOME") "/.gemini"))
  ;; devices
  (literal "/dev/stdout")
  (literal "/dev/stderr")
  (literal "/dev/null")
  (literal "/dev/zero")
  (literal "/dev/tty")
  (literal "/dev/ptmx")
  (literal "/dev/urandom")
  (literal "/dev/random")
  (regex #"^/dev/tty*")
  (regex #"^/dev/pty*")
)

;; --- process control ---
(allow process-exec)
(allow process-fork)
(allow process-info* (target same-sandbox))
(allow signal (target same-sandbox))
(allow mach-priv-task-port (target same-sandbox))
(allow pseudo-tty)
(allow system-socket)

;; --- device files ---
(allow file-ioctl file-read-metadata file-read-data file-write-data
  (literal "/dev/dtracehelper"))
(allow file-ioctl file-read-metadata file-read-data file-write-data
  (require-all (literal "/dev/null") (vnode-type CHARACTER-DEVICE)))

;; --- sysctl (hardware & kernel info) ---
(allow sysctl-read
  (sysctl-name "hw.activecpu")
  (sysctl-name "hw.busfrequency_compat")
  (sysctl-name "hw.byteorder")
  (sysctl-name "hw.cacheconfig")
  (sysctl-name "hw.cachelinesize_compat")
  (sysctl-name "hw.cpufamily")
  (sysctl-name "hw.cpufrequency_compat")
  (sysctl-name "hw.cputype")
  (sysctl-name "hw.ephemeral_storage")
  (sysctl-name "hw.l1dcachesize_compat")
  (sysctl-name "hw.l1icachesize_compat")
  (sysctl-name "hw.l2cachesize_compat")
  (sysctl-name "hw.l3cachesize_compat")
  (sysctl-name "hw.logicalcpu_max")
  (sysctl-name "hw.machine")
  (sysctl-name "hw.memsize")
  (sysctl-name "hw.ncpu")
  (sysctl-name "hw.optional.arm.FEAT_LSE")
  (sysctl-name "hw.optional.arm.FEAT_SHA3")
  (sysctl-name "hw.optional.arm.FEAT_SHA512")
  (sysctl-name "hw.optional.armv8_1_atomics")
  (sysctl-name "hw.optional.armv8_2_sha3")
  (sysctl-name "hw.optional.armv8_2_sha512")
  (sysctl-name "hw.optional.armv8_crc32")
  (sysctl-name "hw.pagesize")
  (sysctl-name "hw.pagesize_compat")
  (sysctl-name "hw.physicalcpu_max")
  (sysctl-name "hw.tbfrequency_compat")
  (sysctl-name "kern.argmax")
  (sysctl-name "kern.bootargs")
  (sysctl-name "kern.hostname")
  (sysctl-name "kern.maxfilesperproc")
  (sysctl-name "kern.osproductversion")
  (sysctl-name "kern.osrelease")
  (sysctl-name "kern.ostype")
  (sysctl-name "kern.osvariant_status")
  (sysctl-name "kern.osversion")
  (sysctl-name "kern.secure_kernel")
  (sysctl-name "kern.version")
  (sysctl-name "net.routetable.0.0.3.0")
  (sysctl-name "security.mac.lockdown_mode_state")
)

;; --- mach IPC services ---
(allow mach-lookup
  ;; security / keychain
  (global-name "com.apple.SecurityServer")
  (global-name "com.apple.securityd")
  (global-name "com.apple.securityd.xpc")
  (global-name "com.apple.trustd.agent")
  ;; system services
  (global-name "com.apple.sysmond")
  (global-name "com.apple.FSEvents")
  (global-name "com.apple.SystemConfiguration.DNSConfiguration")
  (global-name "com.apple.SystemConfiguration.configd")
  (global-name "com.apple.diagnosticd")
  (global-name "com.apple.logd")
  (global-name "com.apple.system.logger")
  (global-name "com.apple.system.notification_center")
  (global-name "com.apple.distributed_notifications@Uv3")
  (global-name "com.apple.PowerManagement.control")
  (global-name "com.apple.bsd.dirhelper")
  ;; fonts / launch services
  (global-name "com.apple.FontObjectsServer")
  (global-name "com.apple.fonts")
  (global-name "com.apple.lsd.mapdb")
  (global-name "com.apple.coreservices.launchservicesd")
  (global-name "com.apple.audio.systemsoundserver")
  ;; directory services
  (global-name "com.apple.system.opendirectoryd.libinfo")
  (global-name "com.apple.system.opendirectoryd.membership")
)

;; --- keychain (Claude API key via `claude login`) ---
(allow file-read*
  (literal (string-append (param "USER_HOME") "/Library/Keychains/login.keychain-db"))
)

;; --- metadata for Library subdirectories ---
(allow file-read-metadata
  (literal "/dev")
  (literal "/private")
  (literal "/Library")
  (literal (string-append (param "USER_HOME") "/Library"))
  (literal (string-append (param "USER_HOME") "/Library/Caches"))
)
(allow file-read-data (literal "/dev"))

;; --- global preferences (needed by various runtimes) ---
(allow file-read*
  (literal "/Library/Preferences/Logging/com.apple.diagnosticd.filter.plist")
  (literal "/Library/Preferences/.GlobalPreferences.plist")
  (literal "/Library/Preferences/com.apple.networkd.plist")
  (literal (string-append (param "USER_HOME") "/Library/Preferences/.GlobalPreferences.plist"))
  (literal (string-append (param "USER_HOME") "/Library/Preferences/.GlobalPreferences_m.plist"))
  (regex (string-append "^" (param "USER_HOME") "/Library/Preferences/ByHost/\\.GlobalPreferences\\..*\\.plist$"))
  (subpath (string-append (param "USER_HOME") "/Library/Java"))
)

;; --- JVM / Scala build caches ---
(allow file-read* file-write*
  (subpath (string-append (param "USER_HOME") "/.sbt"))
  (subpath (string-append (param "USER_HOME") "/.ivy2"))
  (subpath (string-append (param "USER_HOME") "/.m2"))
  (subpath (string-append (param "USER_HOME") "/.jgit"))
  (subpath (string-append (param "USER_HOME") "/.config/jgit"))
  (subpath (string-append (param "USER_HOME") "/Library/Caches/Coursier"))
)
